{

  "manifest_version": 3,
  "name": "Clickbait Detector",
  "version": "1.0",

  "action": {
    "default_popup": "popup.html"
  },
   "background": {
  "service_worker": "background.js"
},

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8000/*"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}